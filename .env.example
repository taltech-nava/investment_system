OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SERPER_API_KEY=

# Global fallback — used when no task-specific setting is defined
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Per-task overrides (leave blank to fall back to global defaults above)
LLM_PROVIDER_AUDIT=
LLM_MODEL_AUDIT=
LLM_PROVIDER_EXTRACTION=
LLM_MODEL_EXTRACTION=

# Ollama local SLM
OLLAMA_HOST=http://localhost:11434

# RunPod remote SLM
RUNPOD_POD_ID=

DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=investment
